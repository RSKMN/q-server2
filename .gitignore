# P3 Research Lab - Git Ignore Rules
# ===================================

# ============================================
# RAW DATA - DO NOT COMMIT LARGE DATASETS
# ============================================

# Raw datasets (typically multi-GB)
data/raw/**
!data/raw/.gitkeep
!data/raw/*/.gitkeep

# Processed data outputs
data/processed/**/*.h5
data/processed/**/*.hdf5
data/processed/**/*.parquet
data/processed/**/*.pkl
data/processed/**/*.pickle
data/processed/**/*.npy
data/processed/**/*.npz
data/processed/**/*.pt
data/processed/**/*.pth
data/processed/**/*.safetensors

# Generated molecules
data/generated/**/*.sdf
data/generated/**/*.mol2
data/generated/**/*.pdb

# Simulation outputs
data/simulations/**/*.trr
data/simulations/**/*.xtc
data/simulations/**/*.dcd
data/simulations/**/*.log

# Embeddings (can be large)
data/processed/embeddings/**/*.npy
data/processed/embeddings/**/*.h5

# Metadata logs (keep schemas, ignore large logs)
data/metadata/**/*.log
data/metadata/**/logs/

# ============================================
# PYTHON
# ============================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/
.conda/

# PyInstaller
*.manifest
*.spec

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# Celery
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Pytest
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# ============================================
# DOCKER & KUBERNETES
# ============================================

# Docker
*.dockerfile.swp
docker-compose.override.yml
.dockerignore.local

# Kubernetes secrets
infrastructure/k8s/secrets/
*.secret.yaml
*.secret.yml

# Helm
infrastructure/helm/charts/*.tgz
infrastructure/helm/.helm/

# ============================================
# ENVIRONMENT & CREDENTIALS
# ============================================

# Environment files
.env
.env.local
.env.*.local
.envrc

# Credentials
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
credentials.json
service-account.json
secrets.yaml
secrets.yml

# Cloud provider configs
.aws/
.azure/
.gcp/

# ============================================
# IDE & EDITORS
# ============================================

# VSCode
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# PyCharm
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# ============================================
# DATABASES
# ============================================

# SQLite
*.db
*.sqlite
*.sqlite3

# PostgreSQL
*.pgsql

# DuckDB
*.duckdb

# ============================================
# LOGS & TEMPORARY FILES
# ============================================

# Logs
logs/
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
tmp/
temp/
*.tmp
*.temp
*.bak
*.swp
*.swo

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============================================
# ML/AI SPECIFIC
# ============================================

# Model checkpoints
models/checkpoints/**/*.pt
models/checkpoints/**/*.pth
models/checkpoints/**/*.h5
models/checkpoints/**/*.ckpt

# Training outputs
runs/
outputs/
lightning_logs/
mlruns/
wandb/

# TensorBoard
events.out.tfevents.*

# ============================================
# KEEP STRUCTURE WITH .gitkeep
# ============================================

# Allow .gitkeep files to maintain empty directories
!.gitkeep
!**/.gitkeep
