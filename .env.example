# P3 Research Lab - Environment Configuration
# ============================================
# Copy this file to .env and configure with your values
# NEVER commit .env to version control

# ============================================
# ENVIRONMENT
# ============================================
P3_ENVIRONMENT=development
# Options: development, staging, production

# ============================================
# DATA PATHS (Absolute or Relative)
# ============================================

# Root data directory
P3_DATA_ROOT=/path/to/research-lab/data

# Raw data directories (organized by source)
P3_RAW_DATA=${P3_DATA_ROOT}/raw
P3_RAW_ZINC=${P3_RAW_DATA}/zinc
P3_RAW_CHEMBL=${P3_RAW_DATA}/chembl
P3_RAW_PDBBIND=${P3_RAW_DATA}/pdbbind
P3_RAW_DRUGBANK=${P3_RAW_DATA}/drugbank

# Processed data directories
P3_PROCESSED_DATA=${P3_DATA_ROOT}/processed
P3_GRAPHS_DATA=${P3_PROCESSED_DATA}/graphs
P3_FEATURES_DATA=${P3_PROCESSED_DATA}/features
P3_EMBEDDINGS_DATA=${P3_PROCESSED_DATA}/embeddings

# Other data directories
P3_GENERATED_DATA=${P3_DATA_ROOT}/generated
P3_SIMULATIONS_DATA=${P3_DATA_ROOT}/simulations
P3_METADATA_PATH=${P3_DATA_ROOT}/metadata

# ============================================
# SERVICE PATHS
# ============================================
P3_PIPELINES_PATH=/path/to/research-lab/pipelines
P3_SERVICES_PATH=/path/to/research-lab/services
P3_SCHEMAS_PATH=/path/to/research-lab/schemas
P3_INFRASTRUCTURE_PATH=/path/to/research-lab/infrastructure
P3_API_PATH=/path/to/research-lab/api

# ============================================
# DATABASE CONFIGURATION
# ============================================

# PostgreSQL (for metadata and structured data)
P3_POSTGRES_HOST=localhost
P3_POSTGRES_PORT=5432
P3_POSTGRES_DB=research_lab
P3_POSTGRES_USER=postgres
P3_POSTGRES_PASSWORD=your_password_here

# Connection string format
P3_DATABASE_URL=postgresql://${P3_POSTGRES_USER}:${P3_POSTGRES_PASSWORD}@${P3_POSTGRES_HOST}:${P3_POSTGRES_PORT}/${P3_POSTGRES_DB}

# MongoDB (optional, for document store)
# P3_MONGO_URI=mongodb://localhost:27017
# P3_MONGO_DB=research_lab

# Redis (for caching)
# P3_REDIS_HOST=localhost
# P3_REDIS_PORT=6379
# P3_REDIS_DB=0

# ============================================
# CLOUD STORAGE (Choose your provider)
# ============================================

# AWS S3
P3_STORAGE_BACKEND=s3
P3_AWS_ACCESS_KEY_ID=your_access_key
P3_AWS_SECRET_ACCESS_KEY=your_secret_key
P3_AWS_REGION=us-east-1
P3_S3_BUCKET=research-lab-data
P3_S3_EMBEDDINGS_PREFIX=embeddings/

# Google Cloud Storage
# P3_STORAGE_BACKEND=gcs
# P3_GCS_PROJECT_ID=your-project-id
# P3_GCS_BUCKET=research-lab-data
# P3_GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Azure Blob Storage
# P3_STORAGE_BACKEND=azure
# P3_AZURE_STORAGE_ACCOUNT=your_account
# P3_AZURE_STORAGE_KEY=your_key
# P3_AZURE_CONTAINER=research-lab-data

# Local filesystem (for development)
# P3_STORAGE_BACKEND=local
# P3_LOCAL_STORAGE_PATH=/path/to/local/storage

# ============================================
# API CONFIGURATION
# ============================================
P3_API_HOST=0.0.0.0
P3_API_PORT=8000
P3_API_WORKERS=4
P3_API_RELOAD=true  # Set to false in production

# CORS
P3_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# API Keys (for authentication)
P3_API_KEY=your_secure_api_key_here
P3_API_SECRET=your_secure_api_secret_here

# JWT Configuration
P3_JWT_SECRET=your_jwt_secret_key_here
P3_JWT_ALGORITHM=HS256
P3_JWT_EXPIRATION=3600  # seconds

# Rate Limiting
P3_RATE_LIMIT_PER_MINUTE=100

# ============================================
# ML MODEL CONFIGURATION
# ============================================

# Model serving
P3_MODEL_CACHE_DIR=/path/to/model/cache
P3_MODEL_DEVICE=cuda  # Options: cuda, cpu, mps
P3_MODEL_BATCH_SIZE=32

# Model registry
P3_MODEL_REGISTRY_URI=s3://research-lab/models
# P3_MLFLOW_TRACKING_URI=http://localhost:5000

# ============================================
# PIPELINE ORCHESTRATION
# ============================================

# Prefect
# P3_PREFECT_API_URL=http://localhost:4200/api

# Airflow
# P3_AIRFLOW_HOME=/path/to/airflow
# P3_AIRFLOW_DAGS_FOLDER=${P3_AIRFLOW_HOME}/dags

# Dagster
# P3_DAGSTER_HOME=/path/to/dagster

# ============================================
# LOGGING & MONITORING
# ============================================
P3_LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
P3_LOG_FORMAT=json  # Options: json, text
P3_LOG_FILE=/var/log/research-lab/p3.log

# Sentry (error tracking)
# P3_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# Prometheus (metrics)
# P3_METRICS_PORT=9090

# ============================================
# DATA VERSIONING
# ============================================

# DVC (Data Version Control)
# P3_DVC_REMOTE=s3://research-lab-dvc
# P3_DVC_CACHE=/path/to/dvc/cache

# ============================================
# VALIDATION SETTINGS
# ============================================
P3_VALIDATION_MODE=strict  # Options: strict, lenient
P3_VALIDATION_FAIL_FAST=false
P3_VALIDATION_MAX_ERRORS=100

# ============================================
# COMPUTE RESOURCES
# ============================================
P3_MAX_WORKERS=8
P3_MAX_MEMORY_GB=32
P3_GPU_MEMORY_FRACTION=0.9

# ============================================
# FEATURE FLAGS
# ============================================
P3_ENABLE_CACHING=true
P3_ENABLE_PROFILING=false
P3_ENABLE_METRICS=true
P3_ENABLE_RATE_LIMITING=true

# ============================================
# EXTERNAL SERVICES
# ============================================

# ChEMBL API
P3_CHEMBL_API_URL=https://www.ebi.ac.uk/chembl/api/data

# PDB API
P3_PDB_API_URL=https://data.rcsb.org/rest/v1

# UniProt API
P3_UNIPROT_API_URL=https://rest.uniprot.org

# ============================================
# KUBERNETES (for production deployment)
# ============================================
# P3_K8S_NAMESPACE=research-lab
# P3_K8S_SERVICE_ACCOUNT=p3-service-account
# P3_K8S_CONFIGMAP=p3-config
# P3_K8S_SECRET=p3-secrets

# ============================================
# DOCKER
# ============================================
# P3_DOCKER_REGISTRY=ghcr.io/your-org
# P3_DOCKER_IMAGE_TAG=latest

# ============================================
# NOTIFICATIONS
# ============================================

# Slack
# P3_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# P3_SLACK_CHANNEL=#research-lab

# Email (SMTP)
# P3_SMTP_HOST=smtp.gmail.com
# P3_SMTP_PORT=587
# P3_SMTP_USER=your_email@example.com
# P3_SMTP_PASSWORD=your_password
# P3_NOTIFICATION_EMAILS=["team@example.com"]

# ============================================
# DEVELOPMENT TOOLS
# ============================================
P3_DEBUG=false
P3_PROFILING=false
P3_ENABLE_HOT_RELOAD=true

# Jupyter
# P3_JUPYTER_PORT=8888
# P3_JUPYTER_TOKEN=your_jupyter_token

# ============================================
# TESTING
# ============================================
P3_TEST_DATA_PATH=/path/to/test/data
P3_TEST_DATABASE_URL=postgresql://postgres:test@localhost:5432/research_lab_test



# Control Embedding Pipeline Behaviour
P3_EMBEDDING_DIM=768
P3_EMBEDDING_BATCH_SIZE=1000 ### TO BE CHANGED TO 5000


# Control feature extraction
P3_FEATURE_BATCH_SIZE=2000
P3_FINGERPRINT_SIZE=2048