# Backend API URL for the Scientific Dashboard
NEXT_PUBLIC_API_URL=http://localhost:8000

# Environment (development, staging, production)
NEXT_PUBLIC_ENVIRONMENT=development

# Optional: API request timeout in milliseconds (default: 30000)
NEXT_PUBLIC_API_TIMEOUT=30000

# Optional: Enable debug logging in browser console
NEXT_PUBLIC_DEBUG=false

# Optional: Log level (error, warn, info, debug)
NEXT_PUBLIC_LOG_LEVEL=info

# Optional: Enable analytics and error reporting
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_ANALYTICS_ID=

# Optional: Feature flags
NEXT_PUBLIC_ENABLE_EXPERIMENTS=true
NEXT_PUBLIC_ENABLE_3D_VIEWER=true
NEXT_PUBLIC_ENABLE_SIMILARITY_SEARCH=true

# Optional: UI Configuration
NEXT_PUBLIC_ITEMS_PER_PAGE=50
NEXT_PUBLIC_MAX_RESULTS=100

# Optional: Third-party integrations
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_GTAG_ID=
